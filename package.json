{
  "name": "codex-memos-evolve",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "author": "911218sky",
  "license": "AGPL-3.0-only",
  "description": "Codex plugin MCP server that evolves usememos/memos notes into policies and skills.",
  "scripts": {
    "build": "tsc",
    "start": "node ./dist/src/mcp-server.js",
    "typecheck": "tsc --noEmit",
    "smoke": "npm run build && node ./dist/tests/smoke.js",
    "mcp:smoke": "npm run build && node ./dist/tests/mcp-smoke.js",
    "plugin:refresh": "bash ./scripts/refresh-plugin.sh",
    "score": "npm run build && node ./dist/scripts/score-project.js",
    "validate": "npm run typecheck && npm run smoke && npm run mcp:smoke && npm run score"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  }
}
