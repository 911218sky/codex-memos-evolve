{
  "name": "codex-memos-evolve",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "author": "911218sky",
  "packageManager": "bun@1.3.14",
  "description": "Codex plugin MCP server that evolves usememos/memos notes into policies and skills.",
  "scripts": {
    "start": "node --no-warnings --experimental-strip-types ./src/mcp-server.ts",
    "typecheck": "tsc --noEmit",
    "smoke": "bun ./tests/smoke.ts",
    "mcp:smoke": "bun ./tests/mcp-smoke.ts",
    "score": "bun ./scripts/score-project.ts",
    "validate": "bun run typecheck && bun run smoke && bun run mcp:smoke && bun run score"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  }
}
