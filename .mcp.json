{
  "mcpServers": {
    "codex-memos-evolve": {
      "cwd": ".",
      "command": "node",
      "args": [
        "--no-warnings",
        "--experimental-strip-types",
        "./src/mcp-server.ts"
      ],
      "env": {
        "MEMOS_BASE_URL": "http://localhost:5230",
        "MEMOS_EVOLVE_LOCAL_FILE": "./.data/local-memos.json"
      },
      "env_vars": [
        "MEMOS_PAT",
        "MEMOS_BASE_URL",
        "MEMOS_EVOLVE_LOCAL_FILE"
      ]
    }
  }
}
